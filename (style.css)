:root {
    --primary: #ff4d6d;
    --envelope-color: #ff85a1;
    --paper: #fffcf2;
}

body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background-color: #ffe5ec;
    margin: 0;
    font-family: 'Poppins', sans-serif;
}

.envelope-wrapper {
    position: relative;
    cursor: pointer;
}

#open { display: none; }

.envelope {
    position: relative;
    width: 320px;
    height: 220px;
    background-color: var(--envelope-color);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

/* Flap ng envelope */
.front-flap {
    position: absolute;
    top: 0;
    z-index: 3;
    border-top: 115px solid #ff99ac;
    border-left: 160px solid transparent;
    border-right: 160px solid transparent;
    transform-origin: top;
    transition: transform 0.5s ease;
}

/* Pocket */
.pocket {
    position: absolute;
    bottom: 0;
    width: 320px;
    height: 110px;
    background-color: #ffb3c1;
    z-index: 4;
}

/* Ang Sulat */
.letter {
    position: absolute;
    bottom: 10px;
    left: 10px;
    width: 300px;
    height: 200px;
    background: var(--paper);
    z-index: 2;
    transition: transform 0.7s ease-in-out;
    padding: 15px;
    box-sizing: border-box;
    box-shadow: 0 -5px 15px rgba(0,0,0,0.05);
}

.text {
    font-family: 'Dancing Script', cursive;
    font-size: 14px;
    color: #444;
    line-height: 1.4;
    text-align: center;
}

.signature {
    text-align: right;
    font-size: 18px;
    margin-top: 5px;
    color: var(--primary);
}

/* Ang Live Heart */
.heart-inside {
    position: absolute;
    top: -25px;
    left: 46%;
    width: 25px;
    height: 25px;
    background: var(--primary);
    transform: rotate(45deg);
    opacity: 0;
}

.heart-inside::before, .heart-inside::after {
    content: "";
    position: absolute;
    width: 25px;
    height: 25px;
    background: var(--primary);
    border-radius: 50%;
}
.heart-inside::before { left: -12.5px; }
.heart-inside::after { top: -12.5px; }

/* Click Interaction */
#open:checked + .envelope .front-flap {
    transform: rotateX(180deg);
    z-index: 1;
}

#open:checked + .envelope .letter {
    transform: translateY(-130px);
    z-index: 2;
}

#open:checked + .envelope .heart-inside {
    opacity: 1;
    animation: floating 2s infinite ease-in-out, heartbeat 0.8s infinite;
}

@keyframes floating {
    0%, 100% { transform: rotate(45deg) translateY(0); }
    50% { transform: rotate(45deg) translateY(-25px); }
}

@keyframes heartbeat {
    0% { transform: rotate(45deg) scale(1); }
    30% { transform: rotate(45deg) scale(1.2); }
    60% { transform: rotate(45deg) scale(1); }
}

.btn-open {
    margin-top: 30px;
    text-align: center;
    background: var(--primary);
    color: white;
    padding: 12px 25px;
    border-radius: 50px;
    font-size: 12px;
    letter-spacing: 1px;
    font-weight: bold;
    box-shadow: 0 5px 15px rgba(255, 77, 109, 0.4);
}
